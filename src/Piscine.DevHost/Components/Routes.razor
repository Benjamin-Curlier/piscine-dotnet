<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(Piscine.Components.MarkdownView).Assembly }"
        NotFoundPage="typeof(Piscine.Components.Components.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Piscine.Components.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
