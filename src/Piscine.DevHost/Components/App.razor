<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Piscine .NET — bootcamp C# / .NET 10, cours et exercices auto-corrigés." />
    <base href="/" />
    <script>
        // Anti-flash : appliqué avant le premier paint, avant le chargement de theme.js. Reflète la
        // même logique que theme.js (préférence 'system'/'light'/'dark' + échelle de police), puis
        // theme.js redéfinit __applyTheme avec les helpers complets (setThemePreference, setFontScale…).
        window.__applyTheme = function () {
            var pref = localStorage.getItem('theme') || 'system';
            var t = (pref === 'light' || pref === 'dark')
                ? pref
                : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', t);
            var s = parseFloat(localStorage.getItem('fontScale'));
            if (isNaN(s)) { s = 1; }
            s = Math.min(1.5, Math.max(0.8, s));
            document.documentElement.style.setProperty('--font-scale', s);
        };
        window.__applyTheme();
    </script>
    <script src="@Assets["_content/Piscine.Components/js/theme.js"]"></script>
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["_content/Piscine.Components/css/piscine.css"]" />
    <link rel="stylesheet" href="@Assets["Piscine.DevHost.styles.css"]" />
    <link rel="stylesheet" href="@Assets["_content/Piscine.Components/lib/xterm/xterm.css"]" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/styles/github-dark.min.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/highlight.min.js"></script>
    <script>
        // toggleTheme / updateThemeIcon / __applyTheme sont définis dans theme.js (RCL).
        function highlightAll() {
            if (!window.hljs) return;
            document.querySelectorAll('pre code:not([data-highlighted])').forEach(function (el) {
                window.hljs.highlightElement(el);
            });
        }
        function onPageReady() {
            // La navigation enhanced peut réécrire <html> : on réapplique le thème.
            window.__applyTheme && window.__applyTheme();
            window.updateThemeIcon && window.updateThemeIcon();
            highlightAll();
        }
        document.addEventListener('DOMContentLoaded', onPageReady);
        window.addEventListener('load', onPageReady);
        if (window.Blazor) {
            Blazor.addEventListener('enhancedload', onPageReady);
        }
    </script>
</body>

</html>
