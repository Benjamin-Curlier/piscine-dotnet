@page "/check"
@page "/check/{ModuleId}/{ExerciseId}"
@rendermode InteractiveServer
@namespace Piscine.Components.Components.Check
@using Piscine.App.Checking
@using Piscine.Components.Services
@inject CourseCatalog Catalog
@inject CheckService Check

<h1 class="check-page-title">Vérifier un exercice</h1>

<div class="check-controls">
    <label for="exo-select" class="check-label">Exercice</label>
    <select id="exo-select" data-testid="exo-select" @bind="_selectedId" class="check-select">
        @foreach (var exercise in AllExercises())
        {
            <option value="@exercise.Id">@exercise.Title</option>
        }
    </select>

    <button data-testid="run-check" class="check-btn" @onclick="RunCheck">Vérifier</button>
</div>

<CheckFeedback Outcome="_outcome" />

@if (_error is not null)
{
    <p data-testid="check-error" class="check-error">Erreur : @_error</p>
}

@if (_running)
{
    <p data-testid="check-running" class="check-running">Correction en cours…</p>
}

@code {
    // Exercice ciblé par l'URL (/check/{ModuleId}/{ExerciseId}) : optionnels, null sur /check nu.
    [Parameter] public string? ModuleId { get; set; }
    [Parameter] public string? ExerciseId { get; set; }

    private string _selectedId = string.Empty;
    private CheckOutcome? _outcome;
    private bool _running;
    private string? _error;
    private string? _autoRunTarget; // exo dont l'auto-correction est programmée (consommée au rendu interactif)
    private string? _lastAutoRun;   // dernier exo auto-corrigé (évite de rejouer sur re-rendu)

    protected override void OnInitialized()
    {
        // Fallback (/check sans paramètre) : pré-sélectionner le premier exercice pour qu'un clic
        // ait toujours une cible. Un exercice passé par l'URL écrase ce choix dans OnParametersSet.
        var first = AllExercises().FirstOrDefault();
        if (first is not null)
        {
            _selectedId = first.Id;
        }
    }

    protected override void OnParametersSet()
    {
        // Sans exercice dans l'URL : on garde la pré-sélection du premier exo, sans auto-correction.
        if (string.IsNullOrWhiteSpace(ExerciseId))
        {
            return;
        }

        var target = AllExercises()
            .FirstOrDefault(e => string.Equals(e.Id, ExerciseId, StringComparison.OrdinalIgnoreCase));
        if (target is null)
        {
            return;
        }

        // Exercice ciblé : le pré-sélectionner (au lieu du premier) et programmer sa correction.
        _selectedId = target.Id;
        if (!string.Equals(_lastAutoRun, target.Id, StringComparison.OrdinalIgnoreCase))
        {
            _autoRunTarget = target.Id;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // L'auto-correction n'a lieu qu'en contexte interactif : OnAfterRender ne s'exécute pas
        // pendant le prérendu serveur, donc la correction (Roslyn + sandbox, coûteuse) ne bloque
        // jamais le premier rendu HTTP. Consommée une seule fois par exercice ciblé.
        if (_autoRunTarget is null || _running)
        {
            return;
        }

        _lastAutoRun = _autoRunTarget;
        _autoRunTarget = null;
        await RunCheck();
    }

    private async Task RunCheck()
    {
        if (string.IsNullOrWhiteSpace(_selectedId) || _running)
        {
            return;
        }

        _running = true;
        _error = null;
        _outcome = null;
        StateHasChanged();

        try
        {
            // La correction in-process (compilation + exécution via Piscine.Grading) est CPU-intensive :
            // on la déporte sur le thread pool pour ne pas bloquer le thread SignalR.
            var id = _selectedId;
            _outcome = await Task.Run(() => Check.Check(id));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    private IEnumerable<CourseExercise> AllExercises()
        => Catalog.Modules
            .SelectMany(m => m.Groups)
            .SelectMany(g => g.Exercises);
}
