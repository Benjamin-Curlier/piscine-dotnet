@namespace Piscine.Components.Components.Check
@using Piscine.App.Checking

@if (Outcome is null)
{
    <p class="check-placeholder">Sélectionne un exercice puis clique sur Vérifier.</p>
}
else
{
    <div class="check-feedback">
        <p class="check-verdict check-verdict--@VerdictCssClass(Outcome.Verdict)" data-testid="check-verdict">
            @VerdictLabel(Outcome.Verdict)
        </p>

        @foreach (var cas in Outcome.Cases.Where(static c => !c.Passed))
        {
            <div class="check-case" data-testid="check-case">
                @foreach (var message in cas.Messages)
                {
                    @if (message.StartsWith("Attendu", StringComparison.Ordinal))
                    {
                        <pre class="diff-line diff-expected" data-testid="diff-expected">@message</pre>
                    }
                    else if (message.StartsWith("Obtenu", StringComparison.Ordinal))
                    {
                        <pre class="diff-line diff-actual" data-testid="diff-actual">@message</pre>
                    }
                    else
                    {
                        <p class="check-message">@message</p>
                    }
                }
            </div>
        }

        @if (Outcome.Hint is not null)
        {
            <article class="hint-card hint-info" data-testid="check-hint">
                <p>@Outcome.Hint</p>
            </article>
        }

        @if (Outcome.CourseRef is not null)
        {
            <a class="check-course-link"
               data-testid="check-course-ref"
               href="/module/@Outcome.ModuleId#@AnchorOf(Outcome.CourseRef)">
                Revoir le cours →
            </a>
        }
    </div>
}

@code {
    [Parameter] public CheckOutcome? Outcome { get; set; }

    private static string VerdictLabel(CheckVerdict verdict) => verdict switch
    {
        CheckVerdict.Reussi => "Réussi",
        CheckVerdict.ARevoir => "À revoir",
        CheckVerdict.AucunFichier => "Aucun fichier rendu",
        CheckVerdict.Introuvable => "Exercice introuvable",
        _ => "Inconnu",
    };

    private static string VerdictCssClass(CheckVerdict verdict) => verdict switch
    {
        CheckVerdict.Reussi => "success",
        CheckVerdict.ARevoir => "error",
        _ => "neutral",
    };

    /// <summary>Extrait le fragment après '#' dans un course_ref, ex. <c>cours.md#hello-world</c> → <c>hello-world</c>.</summary>
    private static string AnchorOf(string courseRef)
    {
        var idx = courseRef.IndexOf('#', StringComparison.Ordinal);
        return idx >= 0 ? courseRef[(idx + 1)..] : string.Empty;
    }
}
