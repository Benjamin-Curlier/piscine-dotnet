@page "/module/{ModuleId}/{ExerciseId}"
@rendermode InteractiveServer
@using Piscine.App.Launch
@using Piscine.App.Settings
@inject CourseCatalog Catalog
@inject WorkspaceLauncher Launcher
@inject SettingsService Settings
@inject NavigationManager Nav

@if (_module is null || _exercise is null)
{
    <PageTitle>Exercice introuvable</PageTitle>
    <div class="notice notice-warn">Exercice <code>@ExerciseId</code> introuvable.</div>
}
else
{
    <PageTitle>@_exercise.Title — @_module.Title</PageTitle>

    <nav class="breadcrumb">
        <a href="/cours">Cours</a> <span>/</span>
        <a href="/module/@_module.Id">@_module.Number — @_module.Title</a> <span>/</span>
        <span>@_exercise.Title</span>
    </nav>

    <header class="exercise-header" data-testid="exercise-page">
        <h1>@_exercise.Title</h1>
        <div class="exercise-meta">
            <span class="badge badge-@_exercise.Difficulty">@_exercise.Difficulty</span>
            @if (_exercise.Bonus)
            {
                <span class="badge badge-bonus">bonus</span>
            }
        </div>
        <p class="exercise-objective">@_exercise.Objective</p>
    </header>

    @if (_exercise.Deliverables.Count > 0)
    {
        <div class="deliverables">
            <span class="deliverables-label">À rendre&nbsp;:</span>
            @foreach (var file in _exercise.Deliverables)
            {
                <code>@file</code>
            }
        </div>
    }

    <div class="exercise-actions" data-testid="exercise-actions">
        <button class="ex-action ex-action-primary" data-testid="ex-open-folder" @onclick="OpenFolder">Ouvrir le dossier</button>
        @if (_editor is not null)
        {
            <button class="ex-action" data-testid="ex-open-editor" @onclick="OpenEditor">Ouvrir dans @_editor.Label</button>
        }
        <button class="ex-action" data-testid="ex-open-terminal-embedded" @onclick="OpenEmbeddedTerminal">Terminal intégré</button>
        <button class="ex-action" data-testid="ex-open-terminal-system" @onclick="OpenSystemTerminal">Terminal système</button>
        <a class="ex-action" data-testid="ex-check" href="/check/@_module.Id/@_exercise.Id">Vérifier</a>
    </div>

    @if (_actionError is not null)
    {
        <div class="notice notice-warn" role="alert" data-testid="ex-action-error">@_actionError</div>
    }

    <CourseToc Markdown="@_exercise.SubjectMarkdown" />
    <MarkdownView Markdown="@_exercise.SubjectMarkdown" />

    <nav class="pager">
        @if (_prev is not null)
        {
            <a class="pager-prev" href="/module/@_module.Id/@_prev.Id">
                <span class="pager-dir">← Précédent</span>
                <span class="pager-title">@_prev.Title</span>
            </a>
        }
        else
        {
            <span></span>
        }
        @if (_next is not null)
        {
            <a class="pager-next" href="/module/@_module.Id/@_next.Id">
                <span class="pager-dir">Suivant →</span>
                <span class="pager-title">@_next.Title</span>
            </a>
        }
        else
        {
            <a class="pager-next" href="/module/@_module.Id">
                <span class="pager-dir">Retour au module →</span>
                <span class="pager-title">@_module.Number — @_module.Title</span>
            </a>
        }
    </nav>
}

@code {
    [Parameter] public string ModuleId { get; set; } = string.Empty;
    [Parameter] public string ExerciseId { get; set; } = string.Empty;

    private CourseModule? _module;
    private CourseExercise? _exercise;
    private CourseExercise? _prev;
    private CourseExercise? _next;
    private EditorOption? _editor;
    private string? _actionError;

    protected override void OnParametersSet()
    {
        _module = Catalog.GetModule(ModuleId);
        _exercise = _module is null ? null : Catalog.GetExercise(ModuleId, ExerciseId);
        _prev = _next = null;
        _editor = null;
        _actionError = null;

        if (_module is null || _exercise is null)
        {
            return;
        }

        _editor = EditorResolver.Resolve(Settings.Load().EditorCommand, ExecutableProbe.OnPath);

        var flat = _module.Groups.SelectMany(g => g.Exercises).ToList();
        var index = flat.FindIndex(e => string.Equals(e.Id, _exercise.Id, StringComparison.OrdinalIgnoreCase));
        _prev = index > 0 ? flat[index - 1] : null;
        _next = index >= 0 && index < flat.Count - 1 ? flat[index + 1] : null;
    }

    // Chaque ouverture délègue à WorkspaceLauncher, qui renvoie false quand le programme externe est
    // introuvable (explorateur / éditeur / terminal absent) : on remonte alors un message actionnable
    // inline plutôt que d'échouer en silence, en orientant la recrue vers le Terminal intégré.
    private void OpenFolder()
        => _actionError = Launcher.OpenFolder(ExerciseId)
            ? null
            : "Impossible d'ouvrir le dossier (explorateur de fichiers introuvable). Utilise le Terminal intégré.";

    private void OpenEditor()
    {
        if (_editor is null)
        {
            return;
        }

        _actionError = Launcher.OpenEditor(ExerciseId, _editor)
            ? null
            : $"Impossible d'ouvrir l'éditeur ({_editor.Label} introuvable). Utilise le Terminal intégré.";
    }

    private void OpenSystemTerminal()
        => _actionError = Launcher.OpenSystemTerminal(ExerciseId)
            ? null
            : "Impossible d'ouvrir le terminal système (application introuvable). Utilise le Terminal intégré.";

    private void OpenEmbeddedTerminal() => Nav.NavigateTo("/terminal");
}
