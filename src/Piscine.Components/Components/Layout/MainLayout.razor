@inherits LayoutComponentBase

<div class="layout">
    @* Poignées de redimensionnement (chromeless Photino : l'OS retire la bordure de resize).
       Masquées hors hôte Photino via CSS — inertes en navigateur. *@
    <div class="resize-handles" aria-hidden="true">
        <div class="rh rh-e"></div><div class="rh rh-s"></div><div class="rh rh-se"></div>
    </div>
    @* S7 — lien d'évitement (a11y clavier) : 1ᵉʳ élément focalisable, masqué hors focus ; saute la
       navigation répétée pour atterrir sur le contenu principal (#main-content). *@
    <a class="skip-link" href="#main-content">Aller au contenu</a>
    <CommandPalette />
    <header class="navbar titlebar-drag">
        <a class="brand no-drag" href="/">
            <span class="brand-mark">{ }</span>
            <span class="brand-text">Piscine <strong>.NET</strong></span>
        </a>
        <nav class="navbar-links no-drag" aria-label="Navigation principale">
            <NavTabs />
            <a href="https://github.com/Benjamin-Curlier/piscine-dotnet" target="_blank" rel="noopener">GitHub</a>
            <button id="theme-toggle" type="button" class="theme-toggle"
                    aria-label="Basculer le thème clair/sombre" onclick="toggleTheme()">☾</button>
        </nav>
        <WindowControls />
    </header>

    <div class="body">
        <aside class="sidebar" aria-label="Plan des cours">
            <NavMenu />
        </aside>
        <main class="main" id="main-content" tabindex="-1">
            <article class="content">
                @Body
            </article>
        </main>
    </div>

    @* S4 — toast de push global (ancre bas-de-shell, après la fermeture de .body). Île interactive :
       le layout est statiquement rendu, ce composant s'abonne au watcher et se met à jour seul. *@
    <ToastHost @rendermode="InteractiveServer" />

    @* S7 — onboarding du 1ᵉʳ lancement (overlay modal). Île interactive : ne s'affiche que si le
       workspace n'est pas encore initialisé (OnboardingState), enrobe InitService, mène au 1ᵉʳ exo. *@
    <OnboardingFlow @rendermode="InteractiveServer" />
</div>

<div id="blazor-error-ui" data-nosnippet>
    Une erreur est survenue.
    <a href="." class="reload">Recharger</a>
    <span class="dismiss">🗙</span>
</div>
