@namespace Piscine.Components.Components
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Piscine.App.Search
@inject SearchService Search
@inject CourseCatalog Catalog
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (_open)
{
    <div class="cmdk-overlay" data-testid="command-palette" @onclick="Close">
        <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Palette de commande"
             @onclick:stopPropagation="true" @onkeydown="OnKeyDown">
            <div class="cmdk-search">
                <span class="cmdk-search-icon" aria-hidden="true">⌕</span>
                <input @ref="_inputRef" class="cmdk-input" type="text" data-testid="command-palette-input"
                       placeholder="Rechercher un module, un exercice, une action…"
                       autocomplete="off" spellcheck="false"
                       value="@_query" @oninput="OnInput" />
                <kbd class="cmdk-hint">Échap</kbd>
            </div>

            @if (_results.Count == 0)
            {
                <p class="cmdk-empty" data-testid="command-palette-empty">Aucun résultat pour « @_query ».</p>
            }
            else
            {
                <ul class="cmdk-results" data-testid="command-palette-results">
                    @for (var i = 0; i < _results.Count; i++)
                    {
                        var index = i;
                        var result = _results[i];
                        var command = result.Command;
                        <li>
                            <button type="button"
                                    class="cmdk-item @(index == _selected ? "selected" : "")"
                                    data-testid="@command.TestId"
                                    data-kind="@command.Kind"
                                    @onclick="() => Activate(command)"
                                    @onmouseenter="() => _selected = index">
                                <span class="cmdk-kind" aria-hidden="true">@KindGlyph(command.Kind)</span>
                                <span class="cmdk-body">
                                    <span class="cmdk-title">@command.Title</span>
                                    @if (result.Snippet is { Length: > 0 } snippet)
                                    {
                                        <span class="cmdk-snippet">@snippet</span>
                                    }
                                    else if (command.Subtitle is { Length: > 0 } subtitle)
                                    {
                                        <span class="cmdk-subtitle">@subtitle</span>
                                    }
                                </span>
                                <span class="cmdk-route">@command.Route</span>
                            </button>
                        </li>
                    }
                </ul>
            }

            <div class="cmdk-footer">
                <span><kbd>↑</kbd><kbd>↓</kbd> naviguer</span>
                <span><kbd>↵</kbd> ouvrir</span>
                <span><kbd>Ctrl</kbd>+<kbd>K</kbd> palette</span>
            </div>
        </div>
    </div>
}

@code {
    private bool _open;
    private string _query = string.Empty;
    private int _selected;
    private IReadOnlyList<SearchResult> _results = [];

    private ElementReference _inputRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<CommandPalette>? _self;
    private bool _registered;
    private bool _focusPending;

    protected override void OnInitialized() => _results = Search.Search(string.Empty);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Enregistrer le hotkey global UNE fois (au 1er rendu), via le module ESM colocalisé.
        if (firstRender && !_registered)
        {
            _registered = true;
            _self = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./_content/Piscine.Components/Components/CommandPalette.razor.js");
            await _module.InvokeVoidAsync("register", _self);
        }

        // Quand l'overlay vient d'ouvrir, focaliser le champ (piège de focus côté JS).
        if (_open && _module is not null && _focusPending)
        {
            _focusPending = false;
            await _module.InvokeVoidAsync("focusInput", _inputRef);
        }
    }

    [JSInvokable]
    public Task OpenFromJs()
    {
        Open();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task ShortcutFromJs(string action)
    {
        if (action == "board")
        {
            Nav.NavigateTo("/");
        }
        else
        {
            NavigateAdjacentExercise(action);
        }

        return Task.CompletedTask;
    }

    private void Open()
    {
        if (_open)
        {
            return;
        }

        _open = true;
        _query = string.Empty;
        _selected = 0;
        _results = Search.Search(string.Empty);
        _focusPending = true;
        StateHasChanged();
    }

    private async Task Close()
    {
        if (!_open)
        {
            return;
        }

        _open = false;
        StateHasChanged();
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("restoreFocus");
        }
    }

    private void OnInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? string.Empty;
        _results = Search.Search(_query);
        _selected = 0;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape":
                await Close();
                break;
            case "ArrowDown":
                if (_results.Count > 0)
                {
                    _selected = (_selected + 1) % _results.Count;
                }
                break;
            case "ArrowUp":
                if (_results.Count > 0)
                {
                    _selected = (_selected - 1 + _results.Count) % _results.Count;
                }
                break;
            case "Enter":
                if (_selected >= 0 && _selected < _results.Count)
                {
                    Activate(_results[_selected].Command);
                }
                break;
        }
    }

    private void Activate(SearchCommand command)
    {
        _open = false;
        Nav.NavigateTo(command.Route);
    }

    private void NavigateAdjacentExercise(string direction)
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
        var segments = relative.Split('/', StringSplitOptions.RemoveEmptyEntries);

        // On n'agit que sur une page d'exercice : /module/{moduleId}/{exerciseId}
        if (segments.Length < 3 || !string.Equals(segments[0], "module", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var moduleId = segments[1];
        var exerciseId = segments[2];
        var module = Catalog.GetModule(moduleId);
        if (module is null)
        {
            return;
        }

        var flat = module.Groups.SelectMany(g => g.Exercises).ToList();
        var current = flat.FindIndex(e => string.Equals(e.Id, exerciseId, StringComparison.OrdinalIgnoreCase));
        if (current < 0)
        {
            return;
        }

        var target = direction == "next" ? current + 1 : current - 1;
        if (target < 0 || target >= flat.Count)
        {
            return;
        }

        Nav.NavigateTo($"/module/{moduleId}/{flat[target].Id}");
    }

    private static string KindGlyph(SearchKind kind) => kind switch
    {
        SearchKind.Destination => "▸",
        SearchKind.Action => "⚡",
        SearchKind.Module => "▤",
        SearchKind.Exercise => "◆",
        _ => "¶",
    };

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit déjà fermé (navigation/reload) : rien à nettoyer côté JS.
            }
            catch (JSException)
            {
                // Module déjà déchargé : nettoyage best-effort.
            }
        }

        _self?.Dispose();
    }
}
