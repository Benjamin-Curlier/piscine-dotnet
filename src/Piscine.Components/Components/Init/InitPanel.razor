@page "/init"
@rendermode InteractiveServer
@namespace Piscine.Components.Components.Init
@using Piscine.App.Init
@using Piscine.App.Progress
@using Piscine.Components.Services
@inject InitService Init
@inject ProgressResetService Reset
@inject CourseCatalog Catalog

<h1 class="init-title">Initialisation de l'environnement</h1>

<div class="init-status-block" data-testid="init-status" data-initialized="@(_status?.IsInitialized.ToString() ?? "False")">
    @if (_status?.IsInitialized == true)
    {
        <span class="init-ok">Déjà initialisé</span>
    }
    else
    {
        <span class="init-pending">Non initialisé</span>
    }
</div>

<button class="init-btn" data-testid="run-init" @onclick="RunInit" disabled="@_running">
    Initialiser
</button>

@if (_outcome is not null)
{
    <div class="init-result" data-testid="init-result" data-success="@_outcome.Success.ToString()">
        <p>@_outcome.Message</p>
    </div>

    @if (_outcome.Error is not null)
    {
        <div class="init-error" data-testid="init-error">
            <p>Erreur : @_outcome.Error</p>
        </div>
    }
}

<section class="init-reset" data-testid="init-reset">
    <h2 class="init-reset-title">Réinitialiser la progression</h2>
    <p class="init-reset-hint">
        Repart de zéro : efface les statuts (Fait / En cours / À revoir). Le code de ton workspace n'est
        pas touché. Action irréversible.
    </p>
    <div class="init-reset-controls">
        <select class="init-reset-scope" data-testid="reset-scope" @bind="_resetScope">
            <option value="">Toute la progression</option>
            @foreach (var module in Catalog.Modules)
            {
                <option value="@module.Id">@module.Id · @module.Title</option>
            }
        </select>
        @if (!_resetArmed)
        {
            <button class="init-btn init-btn-danger" data-testid="reset-arm" @onclick="() => _resetArmed = true">
                Réinitialiser…
            </button>
        }
        else
        {
            <span class="init-reset-confirm">Confirmer ?</span>
            <button class="init-btn init-btn-danger" data-testid="reset-confirm" @onclick="DoReset">
                Oui, réinitialiser
            </button>
            <button class="init-btn init-btn-ghost" data-testid="reset-cancel" @onclick="() => _resetArmed = false">
                Annuler
            </button>
        }
    </div>
    @if (_resetMessage is not null)
    {
        <p class="init-reset-result" data-testid="reset-result">@_resetMessage</p>
    }
</section>

@code {
    private InitStatus? _status;
    private InitOutcome? _outcome;
    private bool _running;

    private string _resetScope = string.Empty;
    private bool _resetArmed;
    private string? _resetMessage;

    protected override void OnInitialized()
    {
        _status = Init.Status();
    }

    private async Task RunInit()
    {
        if (_running)
        {
            return;
        }

        _running = true;
        StateHasChanged();

        try
        {
            _outcome = await Task.Run(() => Init.Initialize());
            _status = _outcome.After;
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    private void DoReset()
    {
        if (string.IsNullOrEmpty(_resetScope))
        {
            Reset.ResetAll();
            _resetMessage = "Progression entièrement réinitialisée.";
        }
        else
        {
            var module = Catalog.GetModule(_resetScope);
            var ids = module is null
                ? Enumerable.Empty<string>()
                : module.Groups.SelectMany(g => g.Exercises).Select(e => e.Id);
            var removed = Reset.ResetExercises(ids);
            _resetMessage = $"Module « {module?.Title ?? _resetScope} » réinitialisé ({removed} exercice(s) effacé(s)).";
        }

        _resetArmed = false;
    }
}
