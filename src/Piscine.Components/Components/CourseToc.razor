@using System.Globalization
@using System.Text
@using System.Text.RegularExpressions

@* Sommaire généré depuis les titres ATX du markdown, ancres cohérentes avec Markdig UseAutoIdentifiers(GitHub). *@

@if (_entries.Count > 0)
{
    <nav class="toc" data-testid="course-toc">
        <ul>
            @foreach (var entry in _entries)
            {
                <li class="toc-level-@entry.Level">
                    <a href="#@entry.Slug">@entry.Text</a>
                </li>
            }
        </ul>
    </nav>
}

@code {
    [Parameter] public string? Markdown { get; set; }
    [Parameter] public int MinLevel { get; set; } = 2;

    private readonly List<(int Level, string Text, string Slug)> _entries = [];

    private static readonly Regex ExplicitId = new(@"\{#(?<id>[^}\s]+)\}\s*$", RegexOptions.Compiled);

    protected override void OnParametersSet()
    {
        _entries.Clear();
        if (string.IsNullOrEmpty(Markdown))
            return;

        foreach (var rawLine in Markdown.Split('\n'))
        {
            var line = rawLine.TrimEnd('\r', ' ', '\t');
            var hashes = 0;
            while (hashes < line.Length && line[hashes] == '#')
                hashes++;

            // Titre ATX = 1 à 6 '#' suivis d'un espace.
            if (hashes is < 1 or > 6 || hashes >= line.Length || line[hashes] != ' ')
                continue;

            if (hashes < MinLevel)
                continue;

            var heading = line[(hashes + 1)..].Trim();
            if (string.IsNullOrWhiteSpace(heading))
                continue;

            var slug = ComputeSlug(heading);
            _entries.Add((hashes, StripExplicitId(heading), slug));
        }
    }

    /// <summary>
    /// Réplique minimalement le slugify de CourseAnchors (privé) :
    /// - ancre explicite {#id} en fin de titre prime
    /// - sinon slug GitHub : minuscules, lettres/chiffres conservés, séparateurs → un tiret
    /// </summary>
    private static string ComputeSlug(string heading)
    {
        var explicitMatch = ExplicitId.Match(heading);
        if (explicitMatch.Success)
            return explicitMatch.Groups["id"].Value;

        return Slugify(heading);
    }

    private static string StripExplicitId(string heading)
    {
        var m = ExplicitId.Match(heading);
        return m.Success ? heading[..m.Index].Trim() : heading;
    }

    /// <summary>Slug façon GitHub : minuscules, lettres/chiffres conservés, séparateurs → un seul tiret.</summary>
    private static string Slugify(string text)
    {
        var sb = new StringBuilder(text.Length);
        var pendingDash = false;
        foreach (var ch in text.ToLowerInvariant().Normalize(NormalizationForm.FormC))
        {
            if (char.IsLetterOrDigit(ch))
            {
                if (pendingDash && sb.Length > 0)
                    sb.Append('-');
                pendingDash = false;
                sb.Append(ch);
            }
            else if (ch == '-' || char.IsWhiteSpace(ch) || char.GetUnicodeCategory(ch) == UnicodeCategory.SpaceSeparator)
            {
                pendingDash = true;
            }
            // tout autre caractère (ponctuation) est ignoré
        }
        return sb.ToString();
    }
}
